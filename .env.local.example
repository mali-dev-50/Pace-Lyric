# Pace Lyric — cloud sync (Supabase). Copy this file to `.env.local` and fill in.
# Both values are PUBLIC (they're used in the browser) and safe to expose; the
# anon key only permits what Row Level Security allows. Never put the SERVICE
# ROLE key here.
#
# Find these in Supabase: Dashboard → Project Settings → API
#   - Project URL      → NEXT_PUBLIC_SUPABASE_URL
#   - anon / public key → NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# Leave both blank to run the app in local-only mode (no accounts, no sync).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
